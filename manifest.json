{
  "manifest_version": 3,
  "name": "Gemini Parallel & Search",
  "version": "1.0",
  "description": "平行分支与时间轴导航插件",
  "permissions": [
    "declarativeNetRequest"
  ],
  "host_permissions": [
    "*://gemini.google.com/*",
    "https://www.google.com/*"
  ],
  "declarative_net_request": {
    "rule_resources": [
      {
        "id": "ruleset_1",
        "enabled": true,
        "path": "rules.json"
      }
    ]
  },
  "content_scripts": [
    {
      "matches": ["*://gemini.google.com/*"],
      "css": ["styles.css"],
      "js": ["content.js"]
    }
  ],
  "background": {
    "service_worker": "background.js"
  }
}
{
  "manifest_version": 3,
  "name": "Gemini 平行对话",
  "version": "1.0",
  "description": "选中文本，开启平行的 Gemini 对话分支",
  "permissions": [
    "activeTab",
    "scripting"
  ],
  "content_scripts": [
    {
      "matches": ["https://gemini.google.com/*"],
      "css": ["styles.css"],
      "js": ["content.js"]
    }
  ]
}